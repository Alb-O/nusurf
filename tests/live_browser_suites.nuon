    }
    page_workflow: {
      path: "tests/cdp/browser/page_workflow.nu"
      needsFixture: false
    }
    page_dom: {
      path: "tests/cdp/browser/page_dom.nu"
      needsFixture: false
    }
    events: {
      path: "tests/cdp/browser/events.nu"
      needsFixture: true
    }
    concurrency: {
      path: "tests/cdp/browser/concurrency.nu"
      needsFixture: true
    }
    attached: {
      path: "tests/cdp/browser/attached.nu"
      needsFixture: true
    }
  }
  suites: {
    browser_no_fixture: [
      basic
      disconnects
      large_artifacts
      page_workflow
      page_dom
    ]
    browser_with_fixture: [
      events
      concurrency
      attached
    ]
    browser_all: [
      basic
      disconnects
      large_artifacts
      page_workflow
      page_dom
      events
      concurrency
      attached
    ]
